# ─────────────────────────────────────────────────────────────────────────
# gotyeah-starter — copiez ce fichier en .env et remplissez les valeurs.
# Aucun secret n'est jamais commité (cf. .gitignore).
# ─────────────────────────────────────────────────────────────────────────

# --- GitHub ---------------------------------------------------------------
# Token (classic ou fine-grained) avec les scopes : repo, delete_repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# User ou organisation propriétaire des repos créés.
GITHUB_OWNER=GotYeahStudios
# Repos template par type de site, au format "owner/repo".
# Laissez vide pour créer un repo vierge (auto_init) pour ce type.
GITHUB_TEMPLATE_NEXTJS=GotYeahStudios/template-nextjs
GITHUB_TEMPLATE_STATIC=GotYeahStudios/template-static
GITHUB_TEMPLATE_OTHER=

# --- Cloudflare -----------------------------------------------------------
# Token API avec permissions : Zone.DNS (Edit) + Zone.Zone (Read).
CLOUDFLARE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
# Optionnel : forcez une zone précise. Sinon résolue depuis le domaine.
CLOUDFLARE_ZONE_ID=
# IP publique du Pi (cible du record A).
PI_PUBLIC_IP=203.0.113.10
# État proxied FINAL souhaité (orange cloud) une fois le site en place.
CLOUDFLARE_PROXIED=true
# true = crée le record en DNS-only (gray cloud) le temps que NPM émette le
# certificat Let's Encrypt, puis rebascule en proxied automatiquement.
# Reproduit le flux manuel "DNS-only -> NPM OK -> repasse en proxy".
CLOUDFLARE_DNS_ONLY_DURING_SSL=true

# --- Nginx Proxy Manager --------------------------------------------------
# URL de l'API NPM (port 81). Depuis un conteneur, l'IP LAN du Pi marche partout.
NPM_BASE_URL=http://192.168.1.10:81
NPM_EMAIL=admin@exemple.com
NPM_PASSWORD=changeme
# Hôte vers lequel NPM redirige (défaut = PI_PUBLIC_IP si vide).
# Souvent l'IP LAN du Pi où tournent les conteneurs de sites.
NPM_FORWARD_HOST=192.168.1.10
NPM_FORWARD_SCHEME=http
# E-mail pour Let's Encrypt (défaut = NPM_EMAIL si vide).
LETSENCRYPT_EMAIL=admin@exemple.com
